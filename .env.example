# ============================================
# NextSound Environment Variables (TEMPLATE)
# ============================================
# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real credentials.
# Get Spotify creds at: https://developer.spotify.com/dashboard/applications

# --- Backend (server/index.js) ---
# These are read by the Express server, NOT by the React frontend.
# No VITE_ prefix because the backend never gets bundled to the browser.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Backend port (compose maps this to the host)
PORT=3001

# Frontend origin the backend trusts for CORS.
# Use http://localhost:8080 when running via docker compose.
# Use http://localhost:5173 when running vite dev directly.
FRONTEND_URL=http://localhost:8080

# --- Frontend (Vite) ---
# Variables prefixed with VITE_ get bundled into the React app
# and ARE visible in the browser. Never put secrets here.
VITE_USE_BACKEND_PROXY=true
VITE_PROXY_SERVER_URL=http://localhost:3001
VITE_ENABLE_OFFLINE_CACHE=true
VITE_API_RETRY_ENABLED=true
